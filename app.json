{
  "expo": {
    "name": "El Espinal",
    "slug": "el-espinal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elespinal",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "cl.elespinal.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para adjuntar facturas.",
          "cameraPermission": "Necesitamos acceso a la cámara para fotografiar facturas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c650562e-33fd-4fd4-93bc-28411445474d"
      }
    }
  }
}